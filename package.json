{
  "name": "shop",
  "version": "0.2.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 5000",
    "start:sw": "npm run build && npm run server:sw",
    "build": "ng build --prod",
    "build:qa": "ng build --configuration=qa",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "generate-mock-api-data": "tsc mock-server/buildScripts/generateData.ts && node mock-server/buildScripts/generateData.js",
    "preserver:mock": "npm run generate-mock-api-data",
    "server:mock": "json-server --watch mock-server/buildScripts/db.json --port 3000",
    "server:sw": "http-server -p 5100 -c-1 dist/Shop -P http://10.0.75.1:5100",
    "doc": "compodoc -p src/tsconfig.app.json -s",
    "compile:server": "webpack --config webpack.server.config.js --progress --colors",
    "serve:ssr": "node dist/server",
    "build:ssr": "npm run build:client-and-server-bundles && npm run compile:server",
    "build:client-and-server-bundles": "ng build --prod && ng run Shop:server:production --bundleDependencies all",
    "ssr": "npm run build:ssr && npm run serve:ssr"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/setupJest.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!**/node_modules/**",
      "!**/vendor/**"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^8.2.5",
    "@angular/common": "^8.2.5",
    "@angular/compiler": "^8.2.5",
    "@angular/core": "^8.2.5",
    "@angular/forms": "^8.2.5",
    "@angular/platform-browser": "^8.2.5",
    "@angular/platform-browser-dynamic": "^8.2.5",
    "@angular/platform-server": "^8.2.5",
    "@angular/pwa": "0.803.2",
    "@angular/router": "^8.2.5",
    "@angular/service-worker": "^8.2.5",
    "@ngrx/effects": "^8.3.0",
    "@ngrx/entity": "^8.3.0",
    "@ngrx/router-store": "^8.3.0",
    "@ngrx/store": "^8.3.0",
    "@ngrx/store-devtools": "^8.3.0",
    "@nguniversal/express-engine": "^8.1.1",
    "@nguniversal/module-map-ngfactory-loader": "8.1.1",
    "@types/express": "^4.17.1",
    "bulma": "^0.7.5",
    "core-js": "^3.2.1",
    "express": "^4.15.2",
    "immutable": "^4.0.0-rc.12",
    "rxjs": "^6.5.3",
    "zone.js": "^0.9.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.803.3",
    "@angular/cli": "~8.3.3",
    "@angular/compiler-cli": "^8.2.5",
    "@angular/language-service": "^8.2.5",
    "@compodoc/compodoc": "^1.1.10",
    "@types/jasmine": "~3.4.0",
    "@types/jasminewd2": "~2.0.6",
    "@types/node": "~12.7.4",
    "chalk": "^2.4.2",
    "codelyzer": "~5.1.0",
    "faker": "^4.1.0",
    "http-server": "^0.9.0",
    "jasmine-core": "~3.4.0",
    "jasmine-spec-reporter": "~4.2.1",
    "jest": "^24.9.0",
    "jest-preset-angular": "^7.1.1",
    "json-schema-faker": "^0.5.0-rc17",
    "json-server": "^0.15.1",
    "karma": "~4.3.0",
    "protractor": "~5.4.2",
    "ts-loader": "^5.2.0",
    "tslint": "~5.19.0",
    "typescript": "~3.5.3",
    "webpack-cli": "^3.1.0"
  }
}
