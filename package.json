{
  "name": "shop",
  "version": "0.2.0",
  "scripts": {
    "ng": "ng",
    "postinstall": "ngcc",
    "start": "ng serve --port 5000",
    "start:sw": "npm run build && npm run server:sw",
    "build": "ng build --prod",
    "build:qa": "ng build --configuration=qa",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "generate-mock-api-data": "tsc mock-server/buildScripts/generateData.ts && node mock-server/buildScripts/generateData.js",
    "preserver:mock": "npm run generate-mock-api-data",
    "server:mock": "json-server --watch mock-server/buildScripts/db.json --port 3000",
    "server:sw": "http-server -p 5100 -c-1 dist/Shop -P http://10.0.75.1:5100",
    "doc": "compodoc -p src/tsconfig.app.json -s",
    "compile:server": "webpack --config webpack.server.config.js --progress --colors",
    "serve:ssr": "node dist/server",
    "build:ssr": "npm run build:client-and-server-bundles && npm run compile:server",
    "build:client-and-server-bundles": "ng build --prod && ng run Shop:server:production --bundleDependencies all",
    "ssr": "npm run build:ssr && npm run serve:ssr"
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/setupJest.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!**/node_modules/**",
      "!**/vendor/**"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^10.2.3",
    "@angular/common": "^10.2.3",
    "@angular/compiler": "^10.2.3",
    "@angular/core": "^10.2.3",
    "@angular/forms": "^10.2.3",
    "@angular/platform-browser": "^10.2.3",
    "@angular/platform-browser-dynamic": "^10.2.3",
    "@angular/platform-server": "^10.2.4",
    "@angular/pwa": "0.10.7",
    "@angular/router": "^10.2.3",
    "@angular/service-worker": "^10.2.3",
    "@ngrx/effects": "^10.1.0",
    "@ngrx/entity": "^10.1.0",
    "@ngrx/router-store": "^10.1.0",
    "@ngrx/store": "^10.1.0",
    "@ngrx/store-devtools": "^10.1.0",
    "@nguniversal/express-engine": "^10.1.0",
    "@types/express": "^4.17.1",
    "bulma": "^0.9.1",
    "core-js": "^3.2.1",
    "express": "^4.17.1",
    "rxjs": "^6.5.5",
    "tslib": "^2.0.0",
    "zone.js": "~0.10.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.1002.0",
    "@angular/cli": "~10.2.0",
    "@angular/compiler-cli": "^10.2.3",
    "@angular/language-service": "^10.2.3",
    "@compodoc/compodoc": "^1.1.11",
    "@types/jasmine": "~3.4.6",
    "@types/jasminewd2": "~2.0.8",
    "@types/node": "~12.7.12",
    "chalk": "^2.4.2",
    "codelyzer": "~5.1.2",
    "faker": "^4.1.0",
    "http-server": "^0.12.3",
    "jasmine-core": "~3.4.0",
    "jasmine-spec-reporter": "~4.2.1",
    "jest": "^24.9.0",
    "jest-preset-angular": "^7.1.1",
    "json-schema-faker": "0.5.0-rcv.32",
    "json-server": "^0.16.3",
    "karma": "~5.2.3",
    "protractor": "~7.0.0",
    "ts-loader": "^8.0.12",
    "tslint": "~6.1.3",
    "typescript": "~4.0.5",
    "webpack-cli": "^3.3.12"
  }
}
